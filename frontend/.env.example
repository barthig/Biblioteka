# Frontend Environment Configuration
# Copy this file to .env and configure for your environment

# Backend API URL.
# Leave empty to use same-origin /api proxy and avoid CORS in local/Docker runs.
VITE_API_URL=

# Target used only by Vite dev server proxy.
VITE_PROXY_TARGET=http://localhost:8000

# Feature Flags
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_DIGITAL_ASSETS=true

# Debug Mode
VITE_DEBUG=false

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000
