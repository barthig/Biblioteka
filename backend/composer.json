{
    "name":  "barthig/biblioteka-backend",
    "type":  "project",
    "description":  "Library Management System - Backend API",
    "license":  "proprietary",
    "require":  {
                    "php":  "^8.1",
                    "ext-pdo":  "*",
                    "symfony/framework-bundle":  "^6.4",
                    "symfony/config":  "^6.4",
                    "symfony/dependency-injection":  "^6.4",
                    "symfony/twig-bundle":  "^6.4",
                    "symfony/asset":  "^6.4",
                    "symfony/doctrine-bridge":  "^6.4",
                    "symfony/error-handler":  "^6.4",
                    "symfony/event-dispatcher":  "^6.4",
                    "symfony/filesystem":  "^6.4",
                    "symfony/finder":  "^6.4",
                    "symfony/http-foundation":  "^6.4",
                    "symfony/orm-pack":  "^2.2",
                    "doctrine/doctrine-bundle":  "2.13.3",
                    "symfony/messenger":  "^6.4",
                    "symfony/amqp-messenger":  "^6.4",
                    "symfony/mime":  "^6.4",
                    "symfony/options-resolver":  "^6.4",
                    "symfony/password-hasher":  "^6.4",
                    "symfony/property-access":  "^6.4",
                    "symfony/property-info":  "^6.4",
                    "symfony/serializer-pack":  "^1.3",
                    "symfony/routing":  "^6.4",
                    "symfony/mailer":  "^6.4",
                    "symfony/notifier":  "^6.4",
                    "symfony/http-client":  "^6.4",
                    "nelmio/api-doc-bundle":  "^4.5",
                    "doctrine/dbal":  "^3.8",
                    "symfony/validator":  "^6.4",
                    "symfony/rate-limiter":  "^6.4",
                    "symfony/lock":  "^6.4",
                    "symfony/cache":  "^6.4",
                    "predis/predis":  "^3.3",
                    "friendsofsymfony/elastica-bundle":  "^7.0",
                    "symfony/security-bundle":  "^6.4",
                    "symfony/security-core":  "^6.4",
                    "symfony/security-http":  "^6.4",
                    "nelmio/cors-bundle":  "^2.6",
                    "php-amqplib/php-amqplib":  "^3.6",
                    "firebase/php-jwt":  "^7.0",
                    "doctrine/doctrine-migrations-bundle":  "^3.7",
                    "doctrine/persistence":  "3.3.1",
                    "doctrine/orm":  "2.20"
                },
    "autoload":  {
                     "files":  [
                                   "compat/doctrine_version_aware_platform_driver.php",
                                   "compat/doctrine_well_known_schema_filter_pass.php",
                                   "compat/symfony_app_reference.php",
                                   "compat/symfony_idle_connection_driver.php",
                                   "compat/symfony_idle_connection_listener.php",
                                   "compat/symfony_date_point_type.php"
                               ],
                     "psr-4":  {
                                   "App\\":  "src/"
                               }
                 },
    "autoload-dev":  {
                         "psr-4":  {
                                       "App\\Tests\\":  "tests/"
                                   }
                     },
    "prefer-stable":  true,
    "require-dev":  {
                        "symfony/debug-bundle":  "^6.4",
                        "symfony/dom-crawler":  "^6.4",
                        "symfony/maker-bundle":  "^1.52",
                        "symfony/var-dumper":  "^6.4",
                        "symfony/yaml":  "^6.4",
                        "doctrine/doctrine-fixtures-bundle":  "^4.3",
                        "phpunit/phpunit":  "^10.5",
                        "symfony/browser-kit":  "^6.4",
                        "symfony/css-selector":  "^6.4",
                        "phpstan/phpstan":  "^2.1"
                    },
    "scripts":  {
                    "start":  "symfony server:start",
                    "test":  "php vendor/bin/phpunit"
                },
    "config":  {
                   "allow-plugins":  {
                                         "php-http/discovery":  false
                                     },
                   "platform":  {
                                    "php":  "8.2.30"
                                },
                   "audit":  {
                                 "abandoned":  "ignore"
                             }
               }
}